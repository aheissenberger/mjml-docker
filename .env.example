# Required
API_KEY=your-secret-api-key

# Optional HTTP server port (1-65535)
PORT=3000

# Optional render worker pool tuning
# Number of worker threads dedicated to MJML rendering (>= 1)
RENDER_WORKERS=2
# Maximum queued render requests waiting for an available worker (>= 0)
RENDER_QUEUE_SIZE=64
# Per-request render timeout in milliseconds (>= 1)
RENDER_TIMEOUT_MS=20000

# Optional per-client request rate limiting
# Maximum allowed requests per client within RATE_LIMIT_WINDOW_MS (>= 1)
RATE_LIMIT_MAX_REQUESTS=120
# Rate-limit window length in milliseconds (>= 1)
RATE_LIMIT_WINDOW_MS=60000

# Suggested presets:
# Dev:  RENDER_WORKERS=1, RENDER_QUEUE_SIZE=16,  RENDER_TIMEOUT_MS=10000
# Prod: RENDER_WORKERS=4, RENDER_QUEUE_SIZE=128, RENDER_TIMEOUT_MS=30000
