{
  "name": "node25-ts-api-server",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal self-hosted MJML render API built with Node.js 25+ and native TypeScript.",
  "homepage": "https://github.com/aheissenberger/mjml-docker#readme",
  "bugs": {
    "url": "https://github.com/aheissenberger/mjml-docker/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aheissenberger/mjml-docker.git"
  },
  "type": "module",
  "scripts": {
    "start": "node src/index.ts",
    "dev": "node --watch src/index.ts",
    "format": "oxfmt . --write",
    "lint": "oxlint .",
    "lint:ts": "oxlint . --type-aware --type-check",
    "typecheck": "tsc --noEmit",
    "gh:docker-publish": "sh -c 'ref=${1:-$(git rev-parse --abbrev-ref HEAD)}; gh workflow run docker-publish.yml --ref \"$ref\"' --",
    "test": "node --test",
    "validate:req-files": "node scripts/spec-ledger/validate-req-files.ts",
    "validate:req-index": "node scripts/spec-ledger/validate-req-index.ts",
    "validate:trace-events": "node scripts/spec-ledger/validate-trace-events.ts",
    "spec:validate": "node scripts/spec-ledger/validate-req-files.ts && node scripts/spec-ledger/validate-req-index.ts && node scripts/spec-ledger/validate-trace-events.ts"
  },
  "dependencies": {
    "html-minifier-terser": "^7.2.0",
    "mjml": "^4.18.0"
  },
  "devDependencies": {
    "@types/html-minifier-terser": "^7.0.2",
    "@types/mjml": "^4.7.4",
    "@types/node": "^25.5.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.19.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=25"
  }
}